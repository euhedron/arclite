#!/bin/sh
# arclite gate (pre-push): `audit` blocks on rule violations; `critique` and `suggest` run advisory
# (non-blocking). All three run concurrently (3 AI runs); their output is collected and printed in
# order once they finish — wall-clock is the slowest single run, not the sum.
# Opt-in via `git config core.hooksPath hooks`; skip a push with `ARC_GATE=0 git push`.
if [ "$ARC_GATE" = "0" ]; then
    echo "arclite gate: skipped (ARC_GATE=0)" >&2
    exit 0
fi
echo "arclite: critique + suggest (advisory) and audit (gate), running concurrently…" >&2
out=$(mktemp -d) || { echo "arclite gate: could not create a temp dir" >&2; exit 1; }
arc critique . --include src                    > "$out/critique" 2>&1 &
arc suggest  . --include src                    > "$out/suggest"  2>&1 &
arc audit    . --include src --fail-on-findings > "$out/audit"    2>&1 &
audit_pid=$!
wait "$audit_pid"
status=$?
wait
echo "=== critique (advisory) ==="; cat "$out/critique"
echo "=== suggest (advisory) ===";  cat "$out/suggest"
echo "=== audit (gate) ===";        cat "$out/audit"
rm -rf "$out"
if [ "$status" -ne 0 ]; then
    echo "arclite gate: push BLOCKED (arc audit exit $status). Fix the findings above, or override with 'ARC_GATE=0 git push'." >&2
fi
exit "$status"
