#!/bin/sh
# arclite gate (pre-push): `audit` blocks on rule violations; `critique` and `suggest` run advisory
# (non-blocking) so every push exercises them and their findings are signal. Spends AI tokens (3 runs).
# Opt-in via `git config core.hooksPath hooks`; skip a push with `ARC_GATE=0 git push`.
if [ "$ARC_GATE" = "0" ]; then
    echo "arclite gate: skipped (ARC_GATE=0)" >&2
    exit 0
fi
echo "arclite: critique (advisory)…" >&2
arc critique . --include src
echo "arclite: suggest (advisory)…" >&2
arc suggest . --include src
echo "arclite: audit (gate)…" >&2
arc audit . --include src --fail-on-findings
status=$?
if [ "$status" -ne 0 ]; then
    echo "arclite gate: push BLOCKED (arc audit exit $status). Fix the findings above, or override with 'ARC_GATE=0 git push'." >&2
fi
exit "$status"
