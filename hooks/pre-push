#!/bin/sh
# arclite gate (pre-push). Nothing here is canonical — a hook is configurable by definition; this is
# only what arclite runs today, and it is meant to change. Edit it freely.
#
# Today: just the blocking gate — `arc audit` on the default (Claude) model, which exits non-zero on
# any rule violation and blocks the push. The broad-signal advisories (`critique`/`suggest`) are run
# ad hoc, not every push: on Claude they add cost and stall under concurrent calls (three claude runs
# a push is the passive spend arc exists to avoid), and the codex lane that made them cheap + parallel
# is spend-capped. Run them by hand — `arc run critique`/`suggest` — when you want broad signal, or
# re-add them here (e.g. behind a separate-quota `--backend`) when one is available.
# Opt-in via `git config core.hooksPath hooks`; skip a push with `ARC_GATE=0 git push`.
if [ "$ARC_GATE" = "0" ]; then
    echo "arclite gate: skipped (ARC_GATE=0)" >&2
    exit 0
fi
echo "arclite: running the audit gate…" >&2
arc run audit . --include src --fail-on-findings
status=$?
if [ "$status" -ne 0 ]; then
    echo "arclite gate: push BLOCKED (arc audit exit $status). Fix the findings above, or override with 'ARC_GATE=0 git push'." >&2
fi
exit "$status"
