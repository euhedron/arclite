#!/bin/sh
# arclite pre-push hook. Nothing here is canonical — a hook is configurable by definition; this is only
# what arclite runs today, and it is meant to change. Edit it freely.
#
# Enable for a clone: `git config core.hooksPath .arc/hooks`. Skip one push: `ARC_GATE=0 git push`.
# Disable: unset core.hooksPath.
#
# It runs the gate and the advisories *concurrently*, so the wall-clock is the slowest single run, not
# their sum (concurrent arc/claude calls are fine — `--runs N` relies on the same):
#   - GATE (blocking): `arc run audit` over all of src on the default model — exits non-zero on any rule
#     violation and blocks the push.
#   - ADVISORIES (non-blocking): `arc run critique/suggest/extract` over the pushed diff — defects,
#     what's worth attention, and candidate rules to curate. They run *regardless* of the gate's verdict
#     (a blocked push still surfaces them) and never block. To spread spend across subscriptions, add
#     `--backend codex` to them.
if [ "$ARC_GATE" = "0" ]; then
    echo "arclite gate: skipped (ARC_GATE=0)" >&2
    exit 0
fi

# A tag-only push moves no branch: its commits are already on the remote, gated when they landed, so
# re-running the gate would only re-sample identical code (each fresh audit is a new judgment — a
# release tag shouldn't be a lottery ticket on code that already passed). Gate pushes that move a
# branch ref; the refs arrive on stdin as `<local ref> <local sha> <remote ref> <remote sha>` lines.
branch_push=0
while read -r local_ref _rest; do
    case "$local_ref" in
    refs/tags/*) ;;
    *) branch_push=1 ;;
    esac
done
if [ "$branch_push" -eq 0 ]; then
    echo "arclite gate: tag-only push — its commits were gated when they landed; skipping" >&2
    exit 0
fi

# CI parity (blocking, deterministic): the same checks the GitHub Actions CI workflow runs, so a push
# that would turn CI red is blocked here first — before any AI spend. Cheapest check first; on a tree
# already built locally cargo's cache makes the re-check near-instant. (arclite devs have the Rust
# toolchain; this is arclite's own hook, not the generic `arc init --hook` scaffold.)
echo "=== arclite gate · cargo fmt / clippy / test (CI parity) ===" >&2
if ! cargo fmt --check >&2; then
    echo "arclite gate: push BLOCKED — cargo fmt --check failed (run 'cargo fmt'). Override: 'ARC_GATE=0 git push'." >&2
    exit 1
fi
if ! cargo clippy --all-targets --locked -- -D warnings >&2; then
    echo "arclite gate: push BLOCKED — cargo clippy found warnings (would break CI). Override: 'ARC_GATE=0 git push'." >&2
    exit 1
fi
if ! cargo test --locked >&2; then
    echo "arclite gate: push BLOCKED — cargo test failed (would break CI). Override: 'ARC_GATE=0 git push'." >&2
    exit 1
fi

# Advisories are scoped to the source changes being pushed (origin/main..HEAD) with --no-scan, so their
# signal tracks the change and the cost stays small; the gate, by contrast, re-audits all of src.
adv_includes=""
if git rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
    for f in $(git diff --name-only --diff-filter=d origin/main..HEAD -- src 2>/dev/null); do
        adv_includes="$adv_includes --include $f"
    done
fi

# Read-only tools for the advisories: a diff-scoped context can't see cross-module references, so let
# the advisory consult the rest of the repo at its own judgment instead of flagging what it can't see.
# claude-only — codex rejects --allow-tool before spend (no mapping to its sandbox model yet), so
# resolve the *effective* backend (the configured default; the runs below pass no --backend) and drop
# the tools rather than have every advisory refuse to run.
adv_tools="--allow-tool Read --allow-tool Grep --allow-tool Glob"
if [ "$(arc config get defaults.backend 2>/dev/null)" = "codex" ]; then
    adv_tools=""
fi

# Launch the gate and each advisory concurrently, each to its own temp file (so their streams don't
# interleave); collect them in order once all finish.
gate_out=$(mktemp)
arc run audit . --include src --fail-on-findings >"$gate_out" 2>&1 &
gate_pid=$!

adv_pids=""
adv_outs=""
if [ -n "$adv_includes" ]; then
    for verb in critique suggest extract; do
        out=$(mktemp)
        # shellcheck disable=SC2086  # intended word-split: one --include per changed file, one flag per tool
        arc run "$verb" . --no-scan $adv_includes $adv_tools >"$out" 2>&1 &
        adv_pids="$adv_pids $!"
        adv_outs="$adv_outs $out"
    done
fi

wait "$gate_pid"
gate=$?
for p in $adv_pids; do wait "$p"; done

echo "=== arclite gate · audit ===" >&2
cat "$gate_out" >&2
rm -f "$gate_out"
if [ -n "$adv_outs" ]; then
    echo "=== arclite advisories · critique / suggest / extract (non-blocking) ===" >&2
    # shellcheck disable=SC2086  # intended word-split over the temp-file list
    cat $adv_outs >&2
    rm -f $adv_outs
fi

if [ "$gate" -ne 0 ]; then
    echo "arclite gate: push BLOCKED (arc audit exit $gate). Fix the findings above, or override with 'ARC_GATE=0 git push'." >&2
    exit "$gate"
fi

# Meta-gate (blocking): when the rules or meta-rules themselves change, audit the ruleset against the
# rule-quality meta-rules — so a curated rule can't land example-bound or tied to the system's current
# state (the general-principle discipline, self-enforced). Skipped entirely (zero cost) on a
# rules-unchanged push; runs only once the src gate above has passed.
if git rev-parse --verify --quiet origin/main >/dev/null 2>&1 && [ -n "$(git diff --name-only --diff-filter=d origin/main..HEAD -- .arc/rules .arc/meta-rules 2>/dev/null)" ]; then
    echo "=== arclite meta-gate · rule-quality (rules changed) ===" >&2
    if ! arc run audit . --include .arc/rules --ruleset rule-quality --no-scan --fail-on-findings >&2; then
        echo "arclite meta-gate: push BLOCKED. Sharpen the flagged rule(s), or override with 'ARC_GATE=0 git push'." >&2
        exit 1
    fi
fi
exit 0
